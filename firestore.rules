rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }
    
    function isSuperAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    // System config - readable by all authenticated users, writable by superadmin only
    match /system_config/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Users collection
    match /users/{userId} {
      // Users can read and write their own document
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow write: if isOwner(userId) || isSuperAdmin();

      // User preferences (notifications, 2FA, accent color, etc)
      match /preferences/{document=**} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // API Keys
      match /apiKeys/{document=**} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Activity logs
      match /activityLogs/{document=**} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Profile data
      match /profile/{document=**} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }
    }

    // Bookings
    match /bookings/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isSuperAdmin();
    }

    // Services
    match /services/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isSuperAdmin();
    }

    // Notifications
    match /notifications/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isSuperAdmin();
    }

    // Payments
    match /payments/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isSuperAdmin();
    }
  }
}
